---
// Courses.astro
import { ArrowRight } from "@lucide/astro";
import { Image } from "astro:assets";
import Button from "./ui/Button.astro";

const courses = [
  {
    title: "Metodo Dullius",
    description:
      "Danca classica, moderna, acrobatica e expressão em uma só aula.",
    image: "/images/short-2.png",
    age: "A partir de 2 anos",
    href: "/cursos/metodo-dullius",
  },
  {
    title: "Ballet",
    description:
      "A dança mais tradicional, ensinada de maneira inovadora e com técnica refinada.",
    image: "/images/short-3.webp",
    age: "Todas as idades",
    href: "/cursos/metodo-dullius",
  },
  {
    title: "Jazz",
    description:
      "Sempre na busca de trabalhos criativos e dinâmicos que exploram ritmo, expressão e energia.",
    image: "/images/short-4.webp",
    age: "A partir de 6 anos",
    href: "/cursos/metodo-dullius",
  },
  {
    title: "Dancas Urbanas",
    description:
      "A dança de rua e pura energia! Hip-Hop, Breaking e muito mais.",
    image: "/images/short-6.webp",
    age: "A partir de 8 anos",
    href: "/cursos/metodo-dullius",
  },
  {
    title: "Adulto",
    description:
      "Qualidade de vida através do movimento. Ballet e Jazz para adultos.",
    image: "/images/short-5.webp",
    age: "Adultos",
    href: "/cursos/metodo-dullius",
  },
  {
    title: "AcroDance",
    description:
      "A fusão perfeita entre ginástica e dança. Flexibilidade e força.",
    image: "/images/short-1.jpg",
    age: "A partir de 6 anos",
    href: "/cursos/metodo-dullius",
  },
];
---

<section id="cursos" class="py-24 lg:py-32 bg-zinc-100">
  <div class="mx-auto max-w-7xl xl:container px-6">
    <div class="mb-16 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary">
        Nossos Cursos
      </p>
      <h2
        class="mt-3 text-4xl text-zinc-900 font-semibold tracking-tight md:text-5xl lg:text-6xl text-balance"
      >
        Encontre o seu ritmo
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-lg xl:text-xl text-zinc-600 leading-relaxed"
      >
        Oferecemos modalidades para todas as idades e níveis, com método
        exclusivo e professores altamente qualificados.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        courses.map((course) => (
          <a
            href={course.href || "#contato"}
            class="group relative overflow-hidden rounded-2xl bg-white"
          >
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={course.image}
                alt={course.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-foreground/20 transition-all duration-300 group-hover:bg-foreground/40" />
              <span class="absolute left-4 top-4 rounded-full bg-white px-3 py-1 text-xs font-medium text-zinc-800 backdrop-blur-sm">
                {course.age}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <h3 class="text-xl text-primary font-semibold">{course.title}</h3>
                <ArrowRight class="h-4 w-4 text-primary transition-transform duration-300 group-hover:translate-x-1" />
              </div>
              <p class="mt-2 text-zinc-700 leading-relaxed">
                {course.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <Button
        href="#contato"
      >
        Agende sua aula experimental
    </Button>
    </div>
  </div>
</section>
