---
// Testimonials.astro
import { ChevronLeft, ChevronRight, Quote } from "@lucide/astro";

const testimonials = [
  {
    name: "Ilda Nocchi",
    role: "Mãe de Alice",
    text: "Pensar no desenvolvimento íntegro do ser humano é pensar também em quanto uma criança precisa ser apostada e acreditada. E isto é o que encontrei na Dullius, que através da seriedade com que trata a arte faz uma grande aposta nas crianças que se sentem parte importante de uma grande construção.",
    initials: "IN",
  },
  {
    name: "Fernanda Almeida",
    role: "Aluna - Jazz Adulto",
    text: "Comecei a dançar aos 35 anos e tinha muito receio. A equipe da Dullius me acolheu de um jeito que me senti em casa desde a primeira aula. Hoje a dança faz parte da minha vida e não consigo imaginar sem.",
    initials: "FA",
  },
  {
    name: "Rafael Oliveira",
    role: "Aluno - Danças Urbanas",
    text: "O nível dos professores de danças urbanas é absurdo. Já fiz aulas em várias escolas de Porto Alegre e nenhuma chega perto da Dullius. A estrutura é impecável e o ambiente é muito gostoso.",
    initials: "RO",
  },
  {
    name: "Lucia Ferreira",
    role: "Mãe de aluna - AcroDance",
    text: "A segurança e o profissionalismo da Dullius me conquistaram. Minha filha pratica AcroDance e a evolução técnica dela, sempre com todo cuidado, me deixa muito tranquila e orgulhosa.",
    initials: "LF",
  },
  {
    name: "Camila Santos",
    role: "Aluna - Ballet Adulto",
    text: "Realizar o sonho de dançar ballet depois dos 40 só foi possível pelo acolhimento da Dullius. As turmas adultas são maravilhosas, o ritmo é respeitoso e a professora é uma inspiração.",
    initials: "CS",
  },
];
---

<section class="py-24 lg:py-32 bg-zinc-50 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary">
        Depoimentos
      </p>
      <h2 class="mt-3 text-4xl text-zinc-900 md:text-5xl lg:text-6xl font-medium tracking-tighter text-balance">
        O que dizem nossos alunos
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg xl:text-xl text-zinc-800 leading-relaxed">
        Histórias reais de quem vive a magia da dança na Dullius Dance.
      </p>
    </div>

    <div class="relative">
      <div 
        class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar" 
        data-testimonials-slider
      >
        {
          testimonials.map((testimonial) => (
            <div
              class="flex-shrink-0 px-3 snap-start"
              data-testimonials-slide
            >
              <div class="flex flex-col gap-4 rounded-2xl border border-zinc-200 bg-white p-6 h-full select-none">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-50 text-primary flex-shrink-0">
                  <Quote class="h-5 w-5" />
                </div>
                <blockquote class="text-sm text-zinc-700 leading-relaxed flex-1">
                  {`"${testimonial.text}"`}
                </blockquote>
                <div class="flex items-center gap-3 pt-4 border-t border-zinc-100">
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-zinc-800 text-white font-semibold text-sm flex-shrink-0">
                    {testimonial.initials}
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-800 text-sm">
                      {testimonial.name}
                    </p>
                    <p class="mt-0.5 text-xs text-zinc-500">
                      {testimonial.role}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-10 flex items-center justify-center gap-4">
        <button
          type="button"
          data-prev-btn
          class="flex h-11 w-11 items-center justify-center rounded-full border border-zinc-200 text-zinc-800 transition-all duration-200 hover:bg-zinc-100 active:scale-95"
          aria-label="Depoimento anterior"
        >
          <ChevronLeft class="h-5 w-5" />
        </button>

        <div class="flex items-center gap-2" data-dots-container></div>

        <button
          type="button"
          data-next-btn
          class="flex h-11 w-11 items-center justify-center rounded-full border border-zinc-200 text-zinc-800 transition-all duration-200 hover:bg-zinc-100 active:scale-95"
          aria-label="Próximo depoimento"
        >
          <ChevronRight class="h-5 w-5" />
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Esconde a barra de scroll mantendo a funcionalidade */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script define:vars={{ totalTestimonials: testimonials.length }}>
  const slider = document.querySelector("[data-testimonials-slider]");
  const prevBtn = document.querySelector("[data-prev-btn]");
  const nextBtn = document.querySelector("[data-next-btn]");
  const dotsContainer = document.querySelector("[data-dots-container]");
  const slides = document.querySelectorAll("[data-testimonials-slide]");

  let currentPage = 0;
  let itemsPerPage = 1;
  let totalPages = 1;

  function getItemsVisible() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 768) return 2;
    return 1.2; // Permite ver um pedaço do próximo slide no mobile
  }

  function setSlideWidths() {
    const visible = getItemsVisible();
    const gap = 0; // O gap já está sendo controlado pelo padding lateral (px-3)
    slides.forEach((slide) => {
      slide.style.width = `${100 / visible}%`;
    });
  }

  function recalculatePages() {
    itemsPerPage = Math.max(1, Math.floor(getItemsVisible()));
    totalPages = Math.ceil(totalTestimonials / itemsPerPage);
    renderDots();
  }

  function renderDots() {
    if (!dotsContainer) return;
    dotsContainer.innerHTML = '';
    for (let i = 0; i < totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = `h-1.5 rounded-full transition-all duration-300 ${i === currentPage ? 'w-6 bg-zinc-800' : 'w-1.5 bg-zinc-300'}`;
      btn.addEventListener('click', () => {
        const slideIndex = i * itemsPerPage;
        scrollToSlide(slideIndex);
      });
      dotsContainer.appendChild(btn);
    }
  }

  function scrollToSlide(index) {
    if (!slider) return;
    const slideWidth = slides[0].offsetWidth;
    slider.scrollTo({
      left: index * slideWidth,
      behavior: 'smooth'
    });
  }

  // Sincroniza os dots e a página atual quando o usuário arrasta manualmente
  function syncStateOnScroll() {
    const slideWidth = slides[0].offsetWidth;
    const scrollPosition = slider.scrollLeft;
    const activeSlideIndex = Math.round(scrollPosition / slideWidth);
    
    const newPage = Math.floor(activeSlideIndex / itemsPerPage);
    
    if (newPage !== currentPage && newPage < totalPages) {
      currentPage = newPage;
      updateDots();
    }
  }

  function updateDots() {
    const dots = dotsContainer.querySelectorAll("button");
    dots.forEach((dot, index) => {
      if (index === currentPage) {
        dot.className = "h-1.5 rounded-full transition-all duration-300 w-6 bg-zinc-800";
      } else {
        dot.className = "h-1.5 rounded-full transition-all duration-300 w-1.5 bg-zinc-300";
      }
    });
  }

  // Eventos
  prevBtn?.addEventListener("click", () => {
    const targetIndex = Math.max(0, (currentPage - 1) * itemsPerPage);
    scrollToSlide(targetIndex);
  });

  nextBtn?.addEventListener("click", () => {
    const targetIndex = Math.min(totalTestimonials - 1, (currentPage + 1) * itemsPerPage);
    scrollToSlide(targetIndex);
  });

  slider?.addEventListener("scroll", syncStateOnScroll);

  window.addEventListener("resize", () => {
    setSlideWidths();
    recalculatePages();
  });

  // Init
  setSlideWidths();
  recalculatePages();
</script>